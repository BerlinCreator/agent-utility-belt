# =============================================================================
# Agent Utility Belt — Environment Variables
# =============================================================================
# Copy to .env and fill in values. Railway injects DATABASE_URL and REDIS_URL
# automatically when you provision Postgres and Redis add-ons.
# =============================================================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development          # development | production | test
LOG_LEVEL=info                # fatal | error | warn | info | debug | trace

# Database (Railway auto-injects this when Postgres add-on is provisioned)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_utility_belt

# Set to true if using PgBouncer or another connection pooler in transaction mode
DATABASE_DISABLE_PREPARE=false

# Redis (Railway auto-injects this when Redis add-on is provisioned)
# Use rediss:// (double-s) for TLS connections on managed Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting (monthly call limits per tier)
RATE_LIMIT_FREE=100
RATE_LIMIT_STARTER=5000
RATE_LIMIT_GROWTH=50000
RATE_LIMIT_BUSINESS=500000

# External APIs (optional — features degrade gracefully without these)
EXCHANGE_RATE_API_KEY=
LIBRETRANSLATE_URL=https://libretranslate.com
