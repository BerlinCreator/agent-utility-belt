{
  "name": "agent-utility-belt",
  "version": "0.1.0",
  "description": "29-API suite for AI agent builders",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "keywords": [
    "api",
    "agent",
    "utility",
    "belt"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bwip-js": "^4.8.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "jsqr": "^1.4.0",
    "nanoid": "^5.1.7",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bwip-js": "^3.2.3",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
